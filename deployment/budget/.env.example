# ---- Caddy ----
# Set to your domain for free HTTPS (point an A record at the server IP first).
# Leave as :80 to serve plain HTTP on the IP (no certificate).
DOMAIN=:80

# ---- Postgres ----
POSTGRES_DB=god_mode_ai
POSTGRES_USER=godmode
POSTGRES_PASSWORD=change-me-strong

# ---- App ----
JWT_SECRET=change-me-to-a-long-random-string

# ---- Optional LLM keys (leave blank to use the offline local model) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
